PORT=4000

# Landmark Landscaping Supabase project — service role key, NOT the anon
# key used in support.html. Get it from:
# Supabase Dashboard -> Project Settings -> API -> service_role secret
SUPABASE_URL=https://bwcsuxvcqmykhckxqgjh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Value stored in support_messages.sender for AI-authored replies.
# support.html renders anything that isn't 'visitor' as an admin-style
# bubble, so this can stay 'ai' without any front-end change.
AI_SENDER_LABEL=ai

# How long the AI waits before replying, giving a human admin a window
# to answer first. Milliseconds.
AI_REPLY_DELAY_MS=3000
